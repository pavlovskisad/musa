# Smart contract config (Base Sepolia testnet)
# NOTE: after redeploying the contract, update ALL three addresses below AND
# the matching env vars in Vercel, then trigger a new Vercel deploy so the
# VITE_* values are baked into the client bundle.
VITE_MUSA_ADDRESS=0x-new-musa-address
VITE_PAXG_ADDRESS=0x-new-mock-paxg-address
VITE_CHAIN_ID=84532
VITE_BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/your-alchemy-key

# Backend-only (for admin-signed createPosition)
MUSA_ADDRESS=0x-new-musa-address
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/your-alchemy-key
ADMIN_PRIVATE_KEY=0x...owner-of-musa-contract
